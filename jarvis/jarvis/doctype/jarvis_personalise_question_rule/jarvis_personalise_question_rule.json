{
  "doctype": "DocType",
  "name": "Jarvis Personalise Question Rule",
  "module": "Jarvis",
  "issingle": 0,
  "custom": 0,
  "engine": "InnoDB",
  "autoname": "hash",
  "field_order": [
    "question",
    "context_md",
    "scope",
    "target_role",
    "target_user",
    "active"
  ],
  "fields": [
    {
      "fieldname": "question",
      "fieldtype": "Small Text",
      "label": "Question",
      "reqd": 1,
      "in_list_view": 1,
      "description": "Generic-tone text materialized verbatim into each in-scope user's Jarvis Personalise Question bank (origin \"From your organisation\")."
    },
    {
      "fieldname": "context_md",
      "fieldtype": "Long Text",
      "label": "Context (Markdown)",
      "description": "Copied into context_md on every question this rule materializes."
    },
    {
      "fieldname": "scope",
      "fieldtype": "Select",
      "label": "Scope",
      "options": "Org\nRole\nUser",
      "default": "Org",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1,
      "description": "Who this rule materializes a question for. Org = every desk user; Role = holders of Target Role; User = Target User only."
    },
    {
      "fieldname": "target_role",
      "fieldtype": "Link",
      "label": "Target Role",
      "options": "Role",
      "depends_on": "eval:doc.scope=='Role'",
      "mandatory_depends_on": "eval:doc.scope=='Role'"
    },
    {
      "fieldname": "target_user",
      "fieldtype": "Link",
      "label": "Target User",
      "options": "User",
      "depends_on": "eval:doc.scope=='User'",
      "mandatory_depends_on": "eval:doc.scope=='User'"
    },
    {
      "fieldname": "active",
      "fieldtype": "Check",
      "label": "Active",
      "default": "1",
      "in_list_view": 1,
      "in_standard_filter": 1,
      "description": "The materialization sweep (daily + on-save) only considers active rules; flipping this off does not retract questions already materialized."
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    }
  ],
  "sort_field": "creation",
  "sort_order": "DESC",
  "track_changes": 1
}
