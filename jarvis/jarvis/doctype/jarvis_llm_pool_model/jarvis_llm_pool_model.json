{
  "doctype": "DocType",
  "name": "Jarvis LLM Pool Model",
  "module": "Jarvis",
  "istable": 1,
  "custom": 0,
  "engine": "InnoDB",
  "field_order": [
    "enabled",
    "provider",
    "model",
    "tier",
    "order",
    "base_url",
    "credential_type",
    "api_key",
    "rotation",
    "subscription_accounts"
  ],
  "fields": [
    {
      "fieldname": "enabled",
      "fieldtype": "Check",
      "label": "Enabled",
      "default": "1",
      "in_list_view": 1
    },
    {
      "fieldname": "provider",
      "fieldtype": "Data",
      "label": "Provider",
      "in_list_view": 1,
      "description": "e.g. openai, anthropic, openai_compat",
      "depends_on": "eval:doc.credential_type=='api_key'"
    },
    {
      "fieldname": "model",
      "fieldtype": "Data",
      "label": "Model",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "tier",
      "fieldtype": "Select",
      "label": "Tier",
      "options": "strong\ncheap",
      "default": "strong",
      "in_list_view": 1
    },
    {
      "fieldname": "order",
      "fieldtype": "Int",
      "label": "Order",
      "default": "0"
    },
    {
      "fieldname": "base_url",
      "fieldtype": "Data",
      "label": "Base URL",
      "description": "for openai_compat upstreams",
      "depends_on": "eval:doc.credential_type=='api_key'"
    },
    {
      "fieldname": "credential_type",
      "fieldtype": "Select",
      "label": "Credential",
      "options": "api_key\nsubscription",
      "default": "api_key",
      "in_list_view": 1
    },
    {
      "fieldname": "api_key",
      "fieldtype": "Password",
      "label": "API Key",
      "depends_on": "eval:doc.credential_type=='api_key'"
    },
    {
      "fieldname": "rotation",
      "fieldtype": "Select",
      "label": "Rotation",
      "options": "sticky\nround_robin\nleast_used",
      "default": "sticky",
      "depends_on": "eval:doc.credential_type=='subscription'"
    },
    {
      "fieldname": "subscription_accounts",
      "fieldtype": "Password",
      "label": "Subscription Accounts (JSON)",
      "description": "Encrypted JSON array of subscription accounts: [{upstream, account_ref, label, oauth_blob}]. Stored on the model row (a child of Jarvis Settings). Grandchild tables are not persisted by Frappe's ORM, so accounts live here, encrypted at rest.",
      "depends_on": "eval:doc.credential_type=='subscription'"
    }
  ],
  "permissions": []
}
