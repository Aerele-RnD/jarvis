{
  "doctype": "DocType",
  "name": "Jarvis LLM Pool",
  "module": "Jarvis",
  "issingle": 1,
  "custom": 0,
  "engine": "InnoDB",
  "track_changes": 1,
  "field_order": [
    "enabled",
    "auto_enabled",
    "routing_mode",
    "preset",
    "models",
    "last_sync_status",
    "last_sync_error"
  ],
  "fields": [
    {
      "fieldname": "enabled",
      "fieldtype": "Check",
      "label": "Proxy Enabled"
    },
    {
      "fieldname": "auto_enabled",
      "fieldtype": "Check",
      "label": "Auto-Enabled",
      "read_only": 1
    },
    {
      "fieldname": "routing_mode",
      "fieldtype": "Select",
      "label": "Routing Mode",
      "options": "dynamic\nfailover",
      "default": "dynamic"
    },
    {
      "fieldname": "preset",
      "fieldtype": "Select",
      "label": "Preset",
      "options": "Balanced\nCost-saver\nMax-reliability\nCustom",
      "default": "Balanced"
    },
    {
      "fieldname": "models",
      "fieldtype": "Table",
      "label": "Models",
      "options": "Jarvis LLM Pool Model"
    },
    {
      "fieldname": "last_sync_status",
      "fieldtype": "Data",
      "label": "Last Sync Status",
      "read_only": 1
    },
    {
      "fieldname": "last_sync_error",
      "fieldtype": "Small Text",
      "label": "Last Sync Error",
      "read_only": 1
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "share": 1,
      "print": 1,
      "email": 1
    }
  ]
}
