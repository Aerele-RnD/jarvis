{
  "doctype": "DocType",
  "name": "Jarvis Macro Run",
  "module": "Jarvis",
  "issingle": 0,
  "custom": 0,
  "engine": "InnoDB",
  "autoname": "hash",
  "field_order": [
    "macro",
    "conversation",
    "status",
    "current_step",
    "total_steps",
    "capacity_attempts",
    "trigger",
    "started_at",
    "finished_at",
    "error"
  ],
  "fields": [
    {
      "fieldname": "macro",
      "fieldtype": "Link",
      "label": "Macro",
      "options": "Jarvis Macro",
      "in_list_view": 1,
      "search_index": 1
    },
    {
      "fieldname": "conversation",
      "fieldtype": "Link",
      "label": "Conversation",
      "options": "Jarvis Conversation",
      "in_list_view": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "queued\nrunning\nwaiting_capacity\ncompleted\nfailed\nstopped",
      "default": "queued",
      "in_list_view": 1,
      "search_index": 1,
      "description": "waiting_capacity (chat-concurrency CDX-19): the step could not be admitted because the site's turn queue was momentarily full. The run does NOT advance; the capacity-resume cron re-attempts the same step next cycle (bounded by capacity_attempts, then failed)."
    },
    {
      "fieldname": "current_step",
      "fieldtype": "Int",
      "label": "Current Step",
      "default": "0"
    },
    {
      "fieldname": "total_steps",
      "fieldtype": "Int",
      "label": "Total Steps",
      "default": "0"
    },
    {
      "fieldname": "capacity_attempts",
      "fieldtype": "Int",
      "label": "Capacity Attempts",
      "default": "0",
      "description": "CDX-19: how many times the capacity-resume cron has re-attempted a waiting_capacity step. Bounded — once it exceeds the ceiling the run fails with an honest 'site stayed busy' reason instead of retrying forever."
    },
    {
      "fieldname": "trigger",
      "fieldtype": "Select",
      "label": "Trigger",
      "options": "manual\nscheduled",
      "default": "manual"
    },
    {
      "fieldname": "started_at",
      "fieldtype": "Datetime",
      "label": "Started At"
    },
    {
      "fieldname": "finished_at",
      "fieldtype": "Datetime",
      "label": "Finished At"
    },
    {
      "fieldname": "error",
      "fieldtype": "Small Text",
      "label": "Error"
    }
  ],
  "permissions": [
    {
      "role": "Jarvis User",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "if_owner": 1
    },
    {
      "role": "System Manager",
      "read": 1
    }
  ],
  "sort_field": "modified",
  "sort_order": "DESC"
}
