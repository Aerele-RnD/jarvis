{
  "doctype": "DocType",
  "name": "Jarvis Skill Promotion Request",
  "module": "Jarvis",
  "issingle": 0,
  "custom": 0,
  "engine": "InnoDB",
  "autoname": "format:JSPR-{#####}",
  "naming_rule": "Expression",
  "field_order": [
    "skill",
    "skill_name",
    "from_scope",
    "to_scope",
    "target_role",
    "note",
    "status",
    "reviewer",
    "decided_at",
    "decision_note"
  ],
  "fields": [
    {
      "fieldname": "skill",
      "fieldtype": "Link",
      "label": "Skill",
      "options": "Jarvis Custom Skill",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1,
      "search_index": 1,
      "description": "The User/Role-scope custom skill this request asks to promote."
    },
    {
      "fieldname": "skill_name",
      "fieldtype": "Data",
      "label": "Skill Name",
      "read_only": 1,
      "in_list_view": 1,
      "description": "The skill's authored slug at request time (for the reviewer board)."
    },
    {
      "fieldname": "from_scope",
      "fieldtype": "Select",
      "label": "From Scope",
      "options": "User\nRole\nOrg",
      "reqd": 1,
      "description": "Snapshot of the skill's scope at request time."
    },
    {
      "fieldname": "to_scope",
      "fieldtype": "Select",
      "label": "To Scope",
      "options": "Role\nOrg",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1,
      "description": "Requested target scope. Must be Role or Org - promotion only ever widens visibility."
    },
    {
      "fieldname": "target_role",
      "fieldtype": "Link",
      "label": "Target Role",
      "options": "Role",
      "depends_on": "eval:doc.to_scope=='Role'",
      "mandatory_depends_on": "eval:doc.to_scope=='Role'"
    },
    {
      "fieldname": "note",
      "fieldtype": "Small Text",
      "label": "Note",
      "description": "The requester's why - shown to the reviewer."
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Pending\nApproved\nRejected",
      "default": "Pending",
      "in_list_view": 1,
      "in_standard_filter": 1,
      "search_index": 1
    },
    {
      "fieldname": "reviewer",
      "fieldtype": "Link",
      "label": "Reviewer",
      "options": "User",
      "read_only": 1,
      "description": "Reviewer who decided this request (Approved/Rejected)."
    },
    {
      "fieldname": "decided_at",
      "fieldtype": "Datetime",
      "label": "Decided At",
      "read_only": 1
    },
    {
      "fieldname": "decision_note",
      "fieldtype": "Small Text",
      "label": "Decision Note",
      "read_only": 1
    }
  ],
  "permissions": [
    {
      "role": "All",
      "read": 1,
      "if_owner": 1
    },
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    }
  ],
  "sort_field": "creation",
  "sort_order": "DESC",
  "track_changes": 1
}
