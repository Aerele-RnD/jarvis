{
  "doctype": "DocType",
  "name": "Jarvis Chat Message",
  "module": "Jarvis",
  "issingle": 0,
  "custom": 0,
  "engine": "InnoDB",
  "autoname": "hash",
  "field_order": [
    "conversation",
    "seq",
    "role",
    "content",
    "streaming",
    "error",
    "recovering",
    "recovery_started_at",
    "openclaw_seq_watermark",
    "was_recovered",
    "tool_name",
    "tool_args",
    "tool_result",
    "tool_status",
    "canvas"
  ],
  "fields": [
    {
      "fieldname": "conversation",
      "fieldtype": "Link",
      "label": "Conversation",
      "options": "Jarvis Conversation",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1,
      "search_index": 1
    },
    {
      "fieldname": "seq",
      "fieldtype": "Int",
      "label": "Sequence",
      "reqd": 1,
      "description": "Monotonic ordering within a conversation."
    },
    {
      "fieldname": "role",
      "fieldtype": "Select",
      "label": "Role",
      "options": "user\nassistant\ntool",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "content",
      "fieldtype": "Long Text",
      "label": "Content"
    },
    {
      "fieldname": "streaming",
      "fieldtype": "Check",
      "label": "Streaming",
      "default": 0,
      "description": "True while an assistant message is mid-stream."
    },
    {
      "fieldname": "error",
      "fieldtype": "Long Text",
      "label": "Error"
    },
    {
      "fieldname": "recovering",
      "fieldtype": "Check",
      "label": "Recovering",
      "default": 0,
      "description": "True while a managed turn timed out or dropped on the bench but openclaw is presumed still working or finished. turn_recovery finalizes it from the gateway snapshot instead of erroring. streaming stays 1 so the UI keeps the spinner."
    },
    {
      "fieldname": "recovery_started_at",
      "fieldtype": "Datetime",
      "label": "Recovery Started At",
      "description": "When this row entered the recovering state. Bounds the recovery window against an absolute ceiling."
    },
    {
      "fieldname": "openclaw_seq_watermark",
      "fieldtype": "Int",
      "label": "Openclaw Seq Watermark",
      "read_only": 1,
      "hidden": 1,
      "description": "Highest openclaw transcript seq observed before this turn's chat.send; snapshot recovery only finalizes from strictly newer assistant messages."
    },
    {
      "fieldname": "was_recovered",
      "fieldtype": "Check",
      "label": "Was Recovered",
      "default": 0,
      "read_only": 1,
      "hidden": 1,
      "description": "Set when this turn was finalized or errored by snapshot recovery rather than its live worker - the never-error machinery's fingerprint."
    },
    {
      "fieldname": "tool_name",
      "fieldtype": "Data",
      "label": "Tool Name",
      "depends_on": "eval:doc.role=='tool'"
    },
    {
      "fieldname": "tool_args",
      "fieldtype": "JSON",
      "label": "Tool Args",
      "depends_on": "eval:doc.role=='tool'"
    },
    {
      "fieldname": "tool_result",
      "fieldtype": "JSON",
      "label": "Tool Result",
      "depends_on": "eval:doc.role=='tool'"
    },
    {
      "fieldname": "tool_status",
      "fieldtype": "Select",
      "label": "Tool Status",
      "options": "\nrunning\ncompleted\nerror",
      "depends_on": "eval:doc.role=='tool'"
    },
    {
      "fieldname": "canvas",
      "fieldtype": "JSON",
      "label": "Canvas",
      "description": "Rich artifacts (chart/canvas) the agent rendered this turn: [{name,title,type,file_url}]."
    }
  ],
  "permissions": [
    {
      "role": "All",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "if_owner": 1
    }
  ],
  "sort_field": "seq",
  "sort_order": "ASC",
  "track_changes": 0
}
